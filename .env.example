# Copy to .env.local for local development (never commit .env.local).

# --- Firebase (production — shared leaderboard for all students) ---
# Create a project at https://console.firebase.google.com
# Enable Authentication (Google) and Firestore.
# Deploy rules: firebase deploy --only firestore:rules

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Allow any Google account on these email domains (comma-separated, no @ prefix).
VITE_FIREBASE_ADMIN_EMAIL_DOMAINS=tri-ai.org

# Optional: extra individual emails (e.g. personal Gmail mentors)
# VITE_FIREBASE_ADMIN_EMAILS=mentor@gmail.com

# --- Legacy local-only mode (omit Firebase vars above) ---
# VITE_ADMIN_PASSWORD=change-me-to-a-strong-password
