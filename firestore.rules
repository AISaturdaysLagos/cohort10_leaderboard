rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Student leaderboard — public read, mentor write (Firebase Auth required).
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mentor week snapshots — signed-in mentors only (not public).
    match /snapshots/{snapshotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Shared team assignments (email → team name) — mentors only.
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
