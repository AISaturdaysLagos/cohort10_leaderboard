{
  "name": "tri-ai-saturdays-league",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "dev:clean": "node scripts/kill-dev-port.mjs && node ./node_modules/vite/bin/vite.js",
    "build": "tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "build:pages": "VITE_BASE_PATH=/cohort10_leaderboard/ npm run build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "preview:pages": "VITE_BASE_PATH=/cohort10_leaderboard/ node ./node_modules/vite/bin/vite.js preview",
    "firebase": "node ./node_modules/firebase-tools/lib/bin/firebase.js",
    "firebase:login": "node ./node_modules/firebase-tools/lib/bin/firebase.js login",
    "firebase:login-reauth": "node ./node_modules/firebase-tools/lib/bin/firebase.js login --reauth",
    "firebase:deploy-rules": "node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only firestore:rules",
    "firebase:seed-team-map": "node scripts/seed-team-map.mjs",
    "firebase:seed-team-leaders": "node scripts/seed-team-leaders.mjs",
    "firebase:seed-team-descriptions": "node scripts/seed-team-descriptions.mjs",
    "firebase:seed-team-discord": "node scripts/seed-team-discord.mjs",
    "firebase:seed-config": "node scripts/seed-team-map.mjs && node scripts/seed-team-leaders.mjs && node scripts/seed-team-descriptions.mjs && node scripts/seed-team-discord.mjs"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "papaparse": "^5.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "firebase-tools": "^14.0.0",
    "firebase-admin": "^13.4.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.4"
  }
}
