rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Student leaderboard — public read, mentor write (Firebase Auth required).
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mentor week snapshots — signed-in mentors only (not public).
    match /snapshots/{snapshotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Shared config — mentors write; learners read team portal docs when signed in.
    match /config/teamMap {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/teamLeaders {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/teamDescriptions {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/teamDiscord {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/adminDraft {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
