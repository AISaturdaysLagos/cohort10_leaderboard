{
  "name": "tri-ai-saturdays-league",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "node scripts/kill-dev-port.mjs && vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "VITE_BASE_PATH=/cohort10_leaderboard/ npm run build",
    "preview": "vite preview",
